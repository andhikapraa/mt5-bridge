# Copy this file to `.env` in the same directory and fill in your values.
# The skill won't function without BASE_URL and API_KEY.

# Where your mt5-bridge runs. Examples:
#   Tailscale:        http://100.x.y.z:8000
#   Local:            http://localhost:8000
#   Reverse proxy:    https://mt5.example.com
BASE_URL=

# The X-API-Key value your bridge expects (matches the API_KEY in the bridge's deploy/.env).
API_KEY=

# Hard cap per order. Wrapper refuses anything larger; override per-call via env.
MAX_VOLUME=0.10

# Curl timeout per call (seconds).
TIMEOUT=15
