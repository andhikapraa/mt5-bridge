#!/usr/bin/with-contenv bash
# Wine-side mt5linux RPyC server. Also runs first-boot install via
# scripts/install_mt5.sh because wineboot needs a display, and the only
# point at which DISPLAY is reliably up is AFTER KasmVNC has started its
# own service — i.e. inside another service like this one (not cont-init).
set -euo pipefail

WPY_FILE=/config/.mt5bridge/wine_python_path
PIP_MARKER=/config/.mt5bridge/pip.ok

log() { printf '[mt5linux] %s\n' "$*" >&2; }

# Wait for KasmVNC's X display. Linuxserver KasmVNC binds DISPLAY=:0.
: "${DISPLAY:=:0}"
export DISPLAY
log "waiting for X display ${DISPLAY}..."
for _ in $(seq 1 60); do
  if xdpyinfo -display "${DISPLAY}" >/dev/null 2>&1; then
    log "X display ${DISPLAY} is up"
    break
  fi
  sleep 2
done

# First-boot install (idempotent). Skip the whole thing once pip.ok exists.
if [[ ! -f "${PIP_MARKER}" ]]; then
  log "running install_mt5.sh..."
  if ! /app/scripts/install_mt5.sh; then
    log "install_mt5 failed — service will retry on s6 restart"
    exit 1
  fi
fi

WINE_PYTHON="$(cat "${WPY_FILE}")"
if [[ ! -x "${WINE_PYTHON}" ]]; then
  log "ERROR: wine python missing at ${WINE_PYTHON}"
  exit 1
fi

log "starting mt5linux server"
log "  python:  ${WINE_PYTHON}"
log "  bind:    0.0.0.0:${MT5_PORT}"

exec wine "${WINE_PYTHON}" -m mt5linux \
  --host 0.0.0.0 \
  --port "${MT5_PORT}" \
  --mode threaded
