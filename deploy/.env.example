# Copy to .env. NEVER commit .env.
# Generate strong values with: openssl rand -hex 32

API_KEY=                       # Required. Sent as X-API-Key header on every REST call.
VNC_PASSWORD=                  # Required. KasmVNC/x11vnc auth.

# Optional broker auto-login. If all three are set, the bridge logs in on first
# boot of the FastAPI process; otherwise log in manually via noVNC.
MT5_LOGIN=
MT5_PASSWORD=
MT5_SERVER=                    # e.g. HFMarketsGlobal-Demo, Exness-MT5Trial7, XMGlobal-Demo 3
