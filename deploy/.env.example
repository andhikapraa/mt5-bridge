# Copy to .env. NEVER commit .env.
# Generate strong values with: openssl rand -hex 32

CUSTOM_USER=trader             # KasmVNC web UI username
PASSWORD=                      # Required. KasmVNC + x11vnc auth.
API_KEY=                       # Required. Sent as X-API-Key header on every REST call.

# Optional broker auto-login. If all three are set, the FastAPI shim logs in
# on first /account / /order call; otherwise log in manually via the noVNC desktop.
MT5_LOGIN=
MT5_PASSWORD=
MT5_SERVER=                    # e.g. YourBroker-Demo, Exness-MT5Trial7
